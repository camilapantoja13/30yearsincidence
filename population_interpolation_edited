# -----------------------------------------------------------------------------
# 1. Analysis categories
# -----------------------------------------------------------------------------

adult_age_bands <- c("18-19","20-24","25-29","30-34","35-39","40-44","45-49",
                     "50-54","55-59","60-64","65-69","70-74","75-79","80-84","85+")
                     
standardise_age_band <- function(x) {
  x <- gsub("\u2013|\u2014", "-", as.character(x))
  x <- gsub("\\s*-\\s*", "-", x)
  str_trim(x)
}

group_ethnicity <- function(x) {
  case_when(
    str_detect(x, regex("White", ignore_case = TRUE))                      ~ "White",
    str_detect(x, regex("African$|African: African", ignore_case = TRUE))  ~ "Black African",
    str_detect(x, regex("Caribbean$|African: Caribbean", ignore_case = TRUE)) ~ "Black Caribbean",
    str_detect(x, regex("Black British: Other|African: Other Black|Black Other",
                        ignore_case = TRUE))                              ~ "Black Other",
    TRUE                                                                   ~ "Other"
  )
}

standardise_sex <- function(x) {
  case_when(
    x %in% c(1, "1", "M", "Male",   "Males")   ~ "Male",
    x %in% c(2, "2", "F", "Female", "Females") ~ "Female",
    TRUE ~ NA_character_
  )
}

