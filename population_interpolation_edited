                          show_col_types = FALSE) %>%
  rename(LSOA       = `LSOA code (2011)`,
         imd_decile = `Index of Multiple Deprivation (IMD) decile - England`)

ward_quintile_2021 <- ward_lsoa_2021 %>%
  left_join(imd_2019_lsoa, by = c("LSOA_code" = "LSOA")) %>%
  mutate(imd_quintile = ceiling(imd_decile / 2)) %>%
  group_by(ward_2021) %>%
  summarise(imd_quintile = round(mean(imd_quintile, na.rm = TRUE)), .groups = "drop")

age_band_from_single_year <- function(age) {
  as.character(cut(as.numeric(age),
    breaks = c(18, 20, 25, 30, 35, 40, 45, 50, 55, 60, 65, 70, 75, 80, 85, Inf),
    labels = adult_age_bands, right = FALSE))
}

df_2021_adults <- read_excel(file.path(census_dir, "2021.xlsx")) %>%
  rename(ward      = `Electoral wards and divisions`,
         sex       = `Sex (2 categories)`,
         age_code  = `Age (86 categories) Code`,
         ethnicity = `Ethnic group (20 categories)`,
         pop_count = Observation) %>%
  filter(ward %in% wards_2021) %>%
  mutate(age_group         = age_band_from_single_year(age_code),
         ethnicity_grouped = group_ethnicity(ethnicity),
         sex               = standardise_sex(sex)) %>%
  filter(!is.na(age_group)) %>%
  left_join(ward_quintile_2021, by = c("ward" = "ward_2021")) %>%
  group_by(year = 2021, ward, sex, ethnicity_grouped, age_group, imd_quintile) %>%
  summarise(pop_count = sum(pop_count, na.rm = TRUE), .groups = "drop")

# -----------------------------------------------------------------------------
# 5. Interpolation
# -----------------------------------------------------------------------------

pop_census_years <- bind_rows(df_1991_adults, df_2001_adults,
                              df_2011_adults, df_2021_adults) %>%
  mutate(age_group = standardise_age_band(age_group)) %>%
  group_by(year, sex, ethnicity_grouped, age_group, imd_quintile) %>%
  summarise(pop_count = sum(pop_count, na.rm = TRUE), .groups = "drop")

full_grid <- expand_grid(
  year              = 1991:2024,
  sex               = unique(pop_census_years$sex),
  ethnicity_grouped = unique(pop_census_years$ethnicity_grouped),
  age_group         = unique(pop_census_years$age_group),
  imd_quintile      = unique(pop_census_years$imd_quintile)
)

pop_full <- full_grid %>%
  left_join(pop_census_years,
            by = c("year","sex","ethnicity_grouped","age_group","imd_quintile")) %>%
  arrange(sex, ethnicity_grouped, age_group, imd_quintile, year) %>%
  group_by(sex, ethnicity_grouped, age_group, imd_quintile) %>%
  mutate(pop_count_interp = zoo::na.approx(pop_count, x = year,
                                           na.rm = FALSE, rule = 2)) %>%
  ungroup()

write_csv(pop_full, file.path(out_dir, "pop_full_interpolated_with_imd.csv"))
