# --- 1991 ---
df_1991_adults <- read_tsv(file.path(census_dir, "1991.tsv"), show_col_types = FALSE) %>%
  mutate(
    sex       = standardise_sex(str_extract(cell, "(?<=\\().*?(?=\\s*:)")),
    age_group = str_match(cell,
                  "aged\\s+(\\d{1,2}\\s*-\\s*\\d{1,2}|\\d{1,2}\\+|\\d{1,2}\\s+and\\s+over)")[, 2],
    age_group = str_replace(age_group, "\\s+and\\s+over", "+"),
    age_group = standardise_age_band(str_replace_all(age_group, "\\s*", "")),
    ethnicity_grouped = group_ethnicity(
                  str_match(cell, "Ethnic group\\s*:\\s*(.*?)\\s*\\)")[, 2])
  ) %>%
  filter(!str_detect(cell, "Total persons"), age_group %in% adult_age_bands) %>%
  left_join(imd_by_ward_2004, by = c("ward_clean" = "ward")) %>%
  group_by(year = Date, ward = ward_clean, sex, ethnicity_grouped, age_group) %>%
  summarise(pop_count = sum(value, na.rm = TRUE),
            imd_score = first(imd_score), .groups = "drop") %>%
  mutate(imd_quintile = assign_quintile(imd_score, cut_2004))

# --- 2001 ---
df_2001_adults <- read_tsv(file.path(census_dir, "2001.tsv"), show_col_types = FALSE) %>%
  mutate(ward = str_remove(`2003 ST ward`, "^\\S+\\s+"),
         ward = if_else(ward == "Cathedrals", "Cathedral", ward)) %>%
  filter(!str_detect(`Ethnic Grou`, "All categories"),
         !str_detect(Age, "All categories"),
         ward %in% wards_2001) %>%
  mutate(
    ethnicity_grouped = group_ethnicity(
                  str_replace(`Ethnic Grou`, "All categories: Ethnic group: ", "")),
    age_group = str_replace(Age, "^Age ", ""),
    age_group = str_replace_all(age_group, " to ", "-"),
    age_group = standardise_age_band(str_replace(age_group, " and over", "+")),
    age_group = if_else(age_group %in% c("85-89", "90+"), "85+", age_group),
    sex = standardise_sex(Sex)
  ) %>%
  filter(age_group %in% adult_age_bands) %>%
  left_join(imd_by_ward_2004, by = "ward") %>%
  group_by(year = Date, ward, sex, ethnicity_grouped, age_group) %>%
  summarise(pop_count = sum(value, na.rm = TRUE),
            imd_score = first(imd_score), .groups = "drop") %>%
  mutate(imd_quintile = assign_quintile(imd_score, cut_2004))

# --- 2011 ---
df_2011_adults <- read_tsv(file.path(census_dir, "2011.tsv"), show_col_types = FALSE) %>%
  mutate(ward = str_trim(str_remove(`2011 census merged ward`, "^.*:\\s*"))) %>%
  filter(!str_detect(`Ethnic Grou`, "All categories"),
         !str_detect(Age, "All categories"),
         ward %in% wards_2011) %>%
  mutate(
    ethnicity_grouped = group_ethnicity(
                  str_replace(`Ethnic Grou`, "All categories: Ethnic group: ", "")),
    age_group = str_replace(Age, "^Age ", ""),
    age_group = str_replace_all(age_group, " to ", "-"),
    age_group = standardise_age_band(str_replace(age_group, " and over", "+")),
    age_group = if_else(age_group %in% c("85-89", "90+"), "85+", age_group),
    sex = standardise_sex(Sex)
  ) %>%
  filter(age_group %in% adult_age_bands) %>%
  left_join(imd_by_ward_2010 %>% mutate(ward = str_replace(ward, "Cathedral", "Cathedrals")),
            by = "ward") %>%
  group_by(year = Date, ward, sex, ethnicity_grouped, age_group) %>%
  summarise(pop_count = sum(value, na.rm = TRUE),
            imd_score = first(imd_score), .groups = "drop") %>%
  mutate(imd_quintile = assign_quintile(imd_score, cut_2010))

# --- 2021 ---
