# -----------------------------------------------------------------------------
# 3. Deprivation quintiles
# -----------------------------------------------------------------------------

imd_lsoa <- read_csv(file.path(imd_dir, "imd_eng_2004_2007_2010_lsoa01.csv"),
                     show_col_types = FALSE) %>%
  rename(rank_2004  = `2004RANK OF IMD (where 1 is most deprived)`,
         score_2004 = `2004IMD SCORE`,
         rank_2010  = `2010imd_rank`,
         score_2010 = `2010imd_score`)

national_cutpoints <- function(score, rank) {
  s <- score[order(rank)]
  n <- length(s)
  c(s[round(0.2 * n)], s[round(0.4 * n)], s[round(0.6 * n)], s[round(0.8 * n)])
}

cut_2004 <- national_cutpoints(imd_lsoa$score_2004, imd_lsoa$rank_2004)
cut_2010 <- national_cutpoints(imd_lsoa$score_2010, imd_lsoa$rank_2010)

assign_quintile <- function(score, cuts) {
  case_when(
    is.na(score)     ~ NA_integer_,
    score >= cuts[1] ~ 1L,   # most deprived
    score >= cuts[2] ~ 2L,
    score >= cuts[3] ~ 3L,
    score >= cuts[4] ~ 4L,
    TRUE             ~ 5L    # least deprived
  )
}

ward_lsoa <- bind_rows(
  read_csv(file.path(lookup_dir, "lambeth_ward_lsoa_list.csv"), show_col_types = FALSE),
  read_csv(file.path(lookup_dir, "southwark_ward_lsoa_list.csv"), show_col_types = FALSE)
)

imd_by_ward_2004 <- ward_lsoa %>%
  left_join(imd_lsoa, by = "LSOA") %>%
  group_by(ward) %>%
  summarise(imd_score = mean(score_2004, na.rm = TRUE), .groups = "drop")

imd_by_ward_2010 <- ward_lsoa %>%
