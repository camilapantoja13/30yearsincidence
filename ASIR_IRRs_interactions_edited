# -----------------------------------------------------------------------------

asir <- function(df, ...) {
  df %>%
    group_by(...) %>%
    group_modify(~ dsr_gamma(.x$cases, .x$person_years, .x$esp)) %>%
    ungroup() %>%
    mutate(ASIR = sprintf("%.1f (%.1f-%.1f)", rate, lower, upper))
}

