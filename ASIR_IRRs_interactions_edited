irr_within_imd <- function(m, st) {
  if (is.null(m)) return(tibble())
  emm <- emmeans(m$int, ~ ethnicity_group | imd_group, offset = 0)
  contrast(emm, method = "trt.vs.ctrl", ref = 1, type = "response") %>%
    as_tibble() %>%
    transmute(stroke_type = st,
              imd_group,
              comparison = as.character(contrast),
              IRR = sprintf("%.2f (%.2f-%.2f), p=%s",
                            ratio, asymp.LCL, asymp.UCL,
                            ifelse(p.value < 0.001, "<0.001",
                                   sprintf("%.3f", p.value))))
}

