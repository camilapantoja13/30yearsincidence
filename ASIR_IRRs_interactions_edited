marginal_rates <- function(m, st, by_sex = FALSE) {
  if (is.null(m)) return(tibble())
  spec <- if (by_sex) ~ ethnicity_group * imd_group * sex
          else        ~ ethnicity_group * imd_group

  emmeans(m$int, spec, offset = log(1e5), type = "response") %>%
    as_tibble() %>%
    rename(rate = response) %>%
    mutate(stroke_type = st,
           marginal_rate = sprintf("%.1f (%.1f-%.1f)",
                                   rate, asymp.LCL, asymp.UCL))
}

