# -----------------------------------------------------------------------------
# Fay-Feuer gamma confidence intervals
# -----------------------------------------------------------------------------
dsr_gamma <- function(d, n, w, multiplier = 1e5, conf = 0.95) {
  keep <- !is.na(n) & n > 0
  d <- d[keep]; n <- n[keep]; w <- w[keep]
  if (length(d) == 0) return(tibble(rate = NA_real_, lower = NA_real_,
                                    upper = NA_real_, cases = 0))

  w  <- w / sum(w)
  y  <- sum(w * d / n)                 # standardised rate
  v  <- sum(w^2 * d / n^2)             # its variance
  wm <- max(w / n)
  a  <- (1 - conf) / 2

  if (y == 0 || v == 0) {
    lower <- 0
    upper <- if (v == 0) NA_real_ else
      ((v + wm^2) / (2 * (y + wm))) * qchisq(1 - a, 2 * (y + wm)^2 / (v + wm^2))
  } else {
    lower <- (v / (2 * y)) * qchisq(a, 2 * y^2 / v)
    upper <- ((v + wm^2) / (2 * (y + wm))) *
             qchisq(1 - a, 2 * (y + wm)^2 / (v + wm^2))
  }

  tibble(rate  = y * multiplier,
         lower = lower * multiplier,
         upper = upper * multiplier,
         cases = sum(d))
}

