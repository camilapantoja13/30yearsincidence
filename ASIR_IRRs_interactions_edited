# -----------------------------------------------------------------------------
# Period-to-period incidence rate ratios
# -----------------------------------------------------------------------------

period_irr <- function(df, ref_type = c("consecutive","baseline")) {
  ref_type <- match.arg(ref_type)

  map_dfr(subtypes, function(st) {
    d <- df %>% filter(stroke_type == st) %>%
      group_by(period, age_std, sex) %>%
      summarise(cases = sum(cases), person_years = sum(person_years),
                .groups = "drop") %>%
      filter(person_years > 0)

    pairs <- if (ref_type == "baseline") {
      tibble(ref = period_levels[1], cur = period_levels[-1])
    } else {
      tibble(ref = head(period_levels, -1), cur = tail(period_levels, -1))
    }

    pmap_dfr(pairs, function(ref, cur) {
      dd <- d %>% filter(period %in% c(ref, cur)) %>%
        mutate(period = factor(period, levels = c(ref, cur)))
      if (sum(dd$cases) == 0) return(tibble())

      m <- tryCatch(
        glm(cases ~ period + age_std + sex, offset = log(person_years),
            family = poisson, data = dd),
        error = function(e) NULL)
      if (is.null(m)) return(tibble())

      b  <- coef(m); se <- sqrt(diag(vcov(m)))
      i  <- grep("^period", names(b))
      tibble(stroke_type = st, comparison = paste(cur, "vs", ref),
             IRR = sprintf("%.2f (%.2f-%.2f), p=%s",
                           exp(b[i]),
                           exp(b[i] - 1.96 * se[i]),
                           exp(b[i] + 1.96 * se[i]),
                           ifelse(2 * pnorm(-abs(b[i] / se[i])) < 0.001, "<0.001",
                                  sprintf("%.3f", 2 * pnorm(-abs(b[i] / se[i]))))))
    })
  })
}

