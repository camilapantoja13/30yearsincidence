# -----------------------------------------------------------------------------
# Interaction models
# -----------------------------------------------------------------------------

fit_interaction <- function(d, interaction_term) {
  f_main <- as.formula(
    paste("cases ~ ethnicity_group + imd_group + age_group + sex + period"))
  f_int  <- as.formula(
    paste("cases ~", interaction_term, "+ age_group + sex + period +",
          "ethnicity_group + imd_group"))

  m_main <- tryCatch(
    glm(f_main, offset = log(person_years), family = poisson, data = d),
    error = function(e) NULL)
  m_int <- tryCatch(
    glm(f_int, offset = log(person_years), family = poisson, data = d),
    error = function(e) NULL)

  if (is.null(m_main) || is.null(m_int)) return(NULL)
  list(main = m_main, int = m_int,
       lrt = anova(m_main, m_int, test = "Chisq"))
}

models_imd <- setNames(lapply(subtypes, function(st) {
  d <- pooled %>% filter(stroke_type == st) %>% droplevels()
  fit_interaction(d, "ethnicity_group * imd_group")
}), subtypes)

