# -----------------------------------------------------------------------------
# Model fitting
# -----------------------------------------------------------------------------

fit_irr <- function(data, formula) {
  if (nrow(data) == 0 || sum(data$cases) == 0) return(NULL)
  if (n_distinct(data$ethnicity_group) < 2)    return(NULL)

  m <- try(glm(formula, offset = log(person_years),
               family = poisson("log"), data = data), silent = TRUE)
  method <- "Poisson"

  if (inherits(m, "try-error") || !m$converged) {
    if (!requireNamespace("brglm2", quietly = TRUE)) return(NULL)
    m <- try(glm(formula, offset = log(person_years),
                 family = poisson("log"), data = data,
                 method = "brglmFit"), silent = TRUE)
    method <- "Bias-reduced Poisson"
    if (inherits(m, "try-error")) return(NULL)
  }

  tidy(m, exponentiate = TRUE, conf.int = TRUE) %>%
    filter(str_starts(term, "ethnicity_group")) %>%
    transmute(
      ethnicity = sub("^ethnicity_group", "", term),
      estimate, conf.low, conf.high, p.value,
      IRR = sprintf("%.2f (%.2f-%.2f), p=%s", estimate, conf.low, conf.high,
                    ifelse(p.value < 0.001, "<0.001", sprintf("%.3f", p.value))),
      method = method
    )
}

run_all <- function(data, formula, label) {
  strata <- expand_grid(period = period_levels,
                        stroke_type = subtypes,
                        sex_group = c("All","Female","Male"))

  pmap_dfr(strata, function(period, stroke_type, sex_group) {
    d <- data %>% filter(period == !!period, stroke_type == !!stroke_type)
    if (sex_group != "All") d <- filter(d, sex == sex_group)
    d <- droplevels(d)

    # sex drops out of the model when the data are stratified by sex
    f <- if (sex_group == "All") formula else update(formula, . ~ . - sex)

    res <- fit_irr(d, f)
    if (is.null(res)) return(tibble())
    res %>% mutate(period = period, stroke_type = stroke_type,
                   sex_group = sex_group, model = label)
  })
}

